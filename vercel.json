    { "source": "/from-banners-to-monuments-sign-styles-that-drive-foot-traffic-in-columbia-sc", "destination": "/blog/from-banners-to-monuments-sign-styles-that-drive-foot-traffic-in-columbia-sc", "permanent": true },
    { "source": "/the-ultimate-guide-to-eye-catching-storefront-signs-in-columbia-sc", "destination": "/blog/the-ultimate-guide-to-eye-catching-storefront-signs-in-columbia-sc", "permanent": true },
